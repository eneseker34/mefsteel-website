    "adv1_d": "\u041f\u043e-\u043b\u0435\u043a\u0430\u0442\u0430 \u0441\u0433\u0440\u0430\u0434\u0430 \u043f\u043e\u0435\u043c\u0430 \u043f\u043e-\u043c\u0430\u043b\u043a\u0438 \u0441\u0435\u0438\u0437\u043c\u0438\u0447\u043d\u0438 \u0441\u0438\u043b\u0438. \u0412\u0441\u0435\u043a\u0438 \u043f\u0440\u043e\u0435\u043a\u0442 \u0435 \u043e\u0440\u0430\u0437\u043c\u0435\u0440\u0435\u043d \u043f\u043e TBDY 2018/2026.",
    "adv2_t": "5\u201310\u00d7 \u043f\u043e-\u043b\u0435\u043a",
    "adv2_d": "\u041f\u0440\u0438 150\u2013300 kg/m\u00b2, \u0434\u0430\u043b\u0435\u0447 \u043f\u043e\u0434 \u0441\u0442\u043e\u043c\u0430\u043d\u043e\u0431\u0435\u0442\u043e\u043d\u0430. \u041d\u0430\u0442\u043e\u0432\u0430\u0440\u0432\u0430\u043d\u0438\u044f\u0442\u0430 \u0432\u044a\u0440\u0445\u0443 \u043e\u0441\u043d\u043e\u0432\u0438\u0442\u0435 \u0438 \u043f\u043e\u0447\u0432\u0430\u0442\u0430 \u043e\u0441\u0442\u0430\u0432\u0430\u0442 \u043c\u0438\u043d\u0438\u043c\u0430\u043b\u043d\u0438.",
    "adv3_t": "\u0414\u043e\u0441\u0442\u0430\u0432\u043a\u0430 \u0437\u0430 \u0441\u0435\u0434\u043c\u0438\u0446\u0438",
    "adv3_d": "\u0411\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u0435\u043d\u0438\u0435 \u043d\u0430 \u0444\u0430\u0431\u0440\u0438\u0447\u043d\u043e \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0441\u0442\u0432\u043e \u0438 \u0441\u0443\u0445 \u043c\u043e\u043d\u0442\u0430\u0436 \u2014 \u0434\u043d\u0438 \u0438 \u0441\u0435\u0434\u043c\u0438\u0446\u0438 \u0432\u043c\u0435\u0441\u0442\u043e \u043c\u0435\u0441\u0435\u0446\u0438 \u0441\u0442\u0440\u043e\u0438\u0442\u0435\u043b\u0441\u0442\u0432\u043e.",
    "adv4_t": "\u041e\u0433\u043d\u0435\u0443\u0441\u0442\u043e\u0439\u0447\u0438\u0432, \u043d\u0435 \u0433\u043d\u0438\u0435",
    "adv4_d": "\u041f\u043e\u0446\u0438\u043d\u043a\u043e\u0432\u0430\u043d\u0438\u044f\u0442 \u0441\u0442\u043e\u043c\u0430\u043d\u0435\u043d \u0441\u043a\u0435\u043b\u0435\u0442 \u043d\u0435 \u0433\u043e\u0440\u0438 \u0438 \u043d\u0435 \u0440\u044a\u0436\u0434\u044f\u0441\u0432\u0430; \u043d\u0435 \u0433\u043d\u0438\u0435, \u043d\u0435 \u043c\u0443\u0445\u043b\u044f\u0441\u0432\u0430 \u0438 \u043d\u0435 \u043f\u0440\u0438\u0432\u043b\u0438\u0447\u0430 \u043d\u0430\u0441\u0435\u043a\u043e\u043c\u0438.",
    "adv5_t": "\u0412\u0438\u0441\u043e\u043a\u0430 \u0438\u0437\u043e\u043b\u0430\u0446\u0438\u044f",
    "adv5_d": "\u0421\u0438\u043b\u043d\u0430 \u0442\u043e\u043f\u043b\u043e- \u0438 \u0448\u0443\u043c\u043e\u0438\u0437\u043e\u043b\u0430\u0446\u0438\u044f \u0441 \u0438\u043d\u0442\u0435\u0433\u0440\u0438\u0440\u0430\u043d\u0438 \u043f\u0430\u043d\u0435\u043b\u0438 \u043e\u0442 \u043a\u0430\u043c\u0435\u043d\u043d\u0430 \u0432\u0430\u0442\u0430, \u0437\u0430 \u043f\u043e-\u043d\u0438\u0441\u043a\u0438 \u0441\u043c\u0435\u0442\u043a\u0438.",
    "adv6_t": "\u0418\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u0430 \u0433\u0430\u0440\u0430\u043d\u0446\u0438\u044f",
    "adv6_d": "\u041e\u0441\u043d\u043e\u0432\u0430\u043d\u0430 \u043e\u0442 \u0434\u0432\u0430\u043c\u0430 \u0441\u0442\u0440\u043e\u0438\u0442\u0435\u043b\u043d\u0438 \u0438\u043d\u0436\u0435\u043d\u0435\u0440\u0438, MefSteel \u043f\u0440\u0435\u0434\u043e\u0441\u0442\u0430\u0432\u044f \u043f\u043e\u0434\u043f\u0438\u0441\u0430\u043d \u0441\u0442\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u0440\u0430\u0437\u0447\u0435\u0442 \u0437\u0430 \u0432\u0441\u0435\u043a\u0438 \u043f\u0440\u043e\u0435\u043a\u0442.",
    "stats_head": "MefSteel \u0432 \u0446\u0438\u0444\u0440\u0438",
    "stat1_l": "\u0413\u043e\u0434\u0438\u043d\u0438 \u043e\u043f\u0438\u0442 \u043d\u0430 \u0442\u0435\u0440\u0435\u043d",
    "stat2_l": "\u0426\u044f\u043b\u043e\u0441\u0442\u043d\u0438 \u0443\u0441\u043b\u0443\u0433\u0438",
    "stat3_l": "\u041a\u0430\u0442\u0435\u0433\u043e\u0440\u0438\u0438 \u043f\u0440\u043e\u0435\u043a\u0442\u0438",
    "stat4_l": "\u041f\u043e\u0434\u043f\u0438\u0441\u0430\u043d\u0438 \u0441\u0442\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438 \u043e\u0442\u0447\u0435\u0442\u0438"
