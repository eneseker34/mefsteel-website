    "adv_title": "\u03a0\u03c1\u03b1\u03b3\u03bc\u03b1\u03c4\u03b9\u03ba\u03ac \u03c0\u03bb\u03b5\u03bf\u03bd\u03b5\u03ba\u03c4\u03ae\u03bc\u03b1\u03c4\u03b1 \u03ad\u03bd\u03b1\u03bd\u03c4\u03b9 \u03c4\u03bf\u03c5 \u03c3\u03ba\u03c5\u03c1\u03bf\u03b4\u03ad\u03bc\u03b1\u03c4\u03bf\u03c2",
    "adv_sub": "\u03a4\u03b1 \u03c3\u03c5\u03c3\u03c4\u03ae\u03bc\u03b1\u03c4\u03b1 \u03b5\u03bb\u03b1\u03c6\u03c1\u03bf\u03cd \u03c7\u03ac\u03bb\u03c5\u03b2\u03b1 \u03c3\u03c5\u03bd\u03b4\u03c5\u03ac\u03b6\u03bf\u03c5\u03bd \u03b1\u03c3\u03c6\u03ac\u03bb\u03b5\u03b9\u03b1, \u03c4\u03b1\u03c7\u03cd\u03c4\u03b7\u03c4\u03b1 \u03ba\u03b1\u03b9 \u03b1\u03c0\u03bf\u03b4\u03bf\u03c4\u03b9\u03ba\u03cc\u03c4\u03b7\u03c4\u03b1.",
    "adv1_t": "\u0391\u03bd\u03c4\u03b9\u03c3\u03b5\u03b9\u03c3\u03bc\u03b9\u03ba\u03cc",
    "adv1_d": "\u0388\u03bd\u03b1 \u03b5\u03bb\u03b1\u03c6\u03c1\u03cd\u03c4\u03b5\u03c1\u03bf \u03ba\u03c4\u03af\u03c1\u03b9\u03bf \u03b4\u03ad\u03c7\u03b5\u03c4\u03b1\u03b9 \u03bc\u03b9\u03ba\u03c1\u03cc\u03c4\u03b5\u03c1\u03b5\u03c2 \u03c3\u03b5\u03b9\u03c3\u03bc\u03b9\u03ba\u03ad\u03c2 \u03b4\u03c5\u03bd\u03ac\u03bc\u03b5\u03b9\u03c2. \u039a\u03ac\u03b8\u03b5 \u03ad\u03c1\u03b3\u03bf \u03bc\u03b5\u03bb\u03b5\u03c4\u03ac\u03c4\u03b1\u03b9 \u03ba\u03b1\u03c4\u03ac TBDY 2018/2026.",
    "adv2_t": "5\u201310\u00d7 \u03b5\u03bb\u03b1\u03c6\u03c1\u03cd\u03c4\u03b5\u03c1\u03bf",
    "adv2_d": "\u03a3\u03c4\u03b1 150\u2013300 kg/m\u00b2, \u03c0\u03bf\u03bb\u03cd \u03ba\u03ac\u03c4\u03c9 \u03b1\u03c0\u03cc \u03c4\u03bf \u03bf\u03c0\u03bb\u03b9\u03c3\u03bc\u03ad\u03bd\u03bf \u03c3\u03ba\u03c5\u03c1\u03cc\u03b4\u03b5\u03bc\u03b1. \u03a4\u03b1 \u03c6\u03bf\u03c1\u03c4\u03af\u03b1 \u03c3\u03b5 \u03b8\u03b5\u03bc\u03ad\u03bb\u03b9\u03b1 \u03ba\u03b1\u03b9 \u03ad\u03b4\u03b1\u03c6\u03bf\u03c2 \u03c0\u03b1\u03c1\u03b1\u03bc\u03ad\u03bd\u03bf\u03c5\u03bd \u03b5\u03bb\u03ac\u03c7\u03b9\u03c3\u03c4\u03b1.",
    "adv3_t": "\u03a0\u03b1\u03c1\u03ac\u03b4\u03bf\u03c3\u03b7 \u03c3\u03b5 \u03b5\u03b2\u03b4\u03bf\u03bc\u03ac\u03b4\u03b5\u03c2",
    "adv3_d": "\u03a7\u03ac\u03c1\u03b7 \u03c3\u03c4\u03b7\u03bd \u03b5\u03c1\u03b3\u03bf\u03c3\u03c4\u03b1\u03c3\u03b9\u03b1\u03ba\u03ae \u03c0\u03b1\u03c1\u03b1\u03b3\u03c9\u03b3\u03ae \u03ba\u03b1\u03b9 \u03c4\u03b7\u03bd \u03be\u03b7\u03c1\u03ae \u03c3\u03c5\u03bd\u03b1\u03c1\u03bc\u03bf\u03bb\u03cc\u03b3\u03b7\u03c3\u03b7 \u2014 \u03b7\u03bc\u03ad\u03c1\u03b5\u03c2 \u03ba\u03b1\u03b9 \u03b5\u03b2\u03b4\u03bf\u03bc\u03ac\u03b4\u03b5\u03c2 \u03b1\u03bd\u03c4\u03af \u03b3\u03b9\u03b1 \u03bc\u03ae\u03bd\u03b5\u03c2.",
    "adv4_t": "\u0386\u03ba\u03b1\u03c5\u03c3\u03c4\u03bf, \u03b4\u03b5\u03bd \u03c3\u03b1\u03c0\u03af\u03b6\u03b5\u03b9",
    "adv4_d": "\u039f \u03b3\u03b1\u03bb\u03b2\u03b1\u03bd\u03b9\u03c3\u03bc\u03ad\u03bd\u03bf\u03c2 \u03c7\u03b1\u03bb\u03cd\u03b2\u03b4\u03b9\u03bd\u03bf\u03c2 \u03c3\u03ba\u03b5\u03bb\u03b5\u03c4\u03cc\u03c2 \u03b4\u03b5\u03bd \u03ba\u03b1\u03af\u03b3\u03b5\u03c4\u03b1\u03b9 \u03bf\u03cd\u03c4\u03b5 \u03c3\u03ba\u03bf\u03c5\u03c1\u03b9\u03ac\u03b6\u03b5\u03b9\u00b7 \u03b4\u03b5\u03bd \u03c3\u03b1\u03c0\u03af\u03b6\u03b5\u03b9, \u03b4\u03b5\u03bd \u03bc\u03bf\u03c5\u03c7\u03bb\u03b9\u03ac\u03b6\u03b5\u03b9 \u03ba\u03b1\u03b9 \u03b4\u03b5\u03bd \u03c0\u03c1\u03bf\u03c3\u03b5\u03bb\u03ba\u03cd\u03b5\u03b9 \u03ad\u03bd\u03c4\u03bf\u03bc\u03b1.",
    "adv5_t": "\u03a5\u03c8\u03b7\u03bb\u03ae \u03bc\u03cc\u03bd\u03c9\u03c3\u03b7",
    "adv5_d": "\u0399\u03c3\u03c7\u03c5\u03c1\u03ae \u03b8\u03b5\u03c1\u03bc\u03bf\u03bc\u03cc\u03bd\u03c9\u03c3\u03b7 \u03ba\u03b1\u03b9 \u03b7\u03c7\u03bf\u03bc\u03cc\u03bd\u03c9\u03c3\u03b7 \u03bc\u03b5 \u03b5\u03bd\u03c3\u03c9\u03bc\u03b1\u03c4\u03c9\u03bc\u03ad\u03bd\u03b1 \u03c0\u03ac\u03bd\u03b5\u03bb \u03c0\u03b5\u03c4\u03c1\u03bf\u03b2\u03ac\u03bc\u03b2\u03b1\u03ba\u03b1, \u03b3\u03b9\u03b1 \u03c7\u03b1\u03bc\u03b7\u03bb\u03cc\u03c4\u03b5\u03c1\u03bf\u03c5\u03c2 \u03bb\u03bf\u03b3\u03b1\u03c1\u03b9\u03b1\u03c3\u03bc\u03bf\u03cd\u03c2.",
    "adv6_t": "\u0395\u03b3\u03b3\u03cd\u03b7\u03c3\u03b7 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03ba\u03bf\u03cd",
    "adv6_d": "\u0399\u03b4\u03c1\u03c5\u03bc\u03ad\u03bd\u03b7 \u03b1\u03c0\u03cc \u03b4\u03cd\u03bf \u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03bf\u03cd\u03c2 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03ba\u03bf\u03cd\u03c2, \u03b7 MefSteel \u03c0\u03b1\u03c1\u03ad\u03c7\u03b5\u03b9 \u03c5\u03c0\u03bf\u03b3\u03b5\u03b3\u03c1\u03b1\u03bc\u03bc\u03ad\u03bd\u03b7 \u03c3\u03c4\u03b1\u03c4\u03b9\u03ba\u03ae \u03bc\u03b5\u03bb\u03ad\u03c4\u03b7 \u03b3\u03b9\u03b1 \u03ba\u03ac\u03b8\u03b5 \u03ad\u03c1\u03b3\u03bf.",
