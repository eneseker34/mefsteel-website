    "blog1_desc": "\u03a4\u03b9 \u03c6\u03ad\u03c1\u03bd\u03b5\u03b9 \u03bf \u03ba\u03b1\u03bd\u03bf\u03bd\u03b9\u03c3\u03bc\u03cc\u03c2 \u03c4\u03b7\u03c2 \u0395\u03c0\u03af\u03c3\u03b7\u03bc\u03b7\u03c2 \u0395\u03c6\u03b7\u03bc\u03b5\u03c1\u03af\u03b4\u03b1\u03c2 \u03b1\u03c1. 33256; \u03a0\u03bb\u03ae\u03c1\u03b7\u03c2 \u03bf\u03b4\u03b7\u03b3\u03cc\u03c2 \u03b3\u03b9\u03b1 \u03b1\u03c0\u03b1\u03b9\u03c4\u03ae\u03c3\u03b5\u03b9\u03c2 \u03c0\u03c1\u03bf\u03c6\u03af\u03bb, \u03c3\u03b5\u03b9\u03c3\u03bc\u03b9\u03ba\u03cc \u03c3\u03c7\u03b5\u03b4\u03b9\u03b1\u03c3\u03bc\u03cc \u03ba\u03b1\u03b9 \u03b5\u03bd\u03c3\u03c9\u03bc\u03ac\u03c4\u03c9\u03c3\u03b7 TBDY 2018.",
    "blog2_tag": "\u03a3\u03b5\u03b9\u03c3\u03bc\u03cc\u03c2",
    "blog2_title": "\u0395\u03af\u03bd\u03b1\u03b9 \u03c4\u03bf \u03b5\u03bb\u03b1\u03c6\u03c1\u03cd \u03c7\u03b1\u03bb\u03cd\u03b2\u03b4\u03b9\u03bd\u03bf \u03c3\u03c0\u03af\u03c4\u03b9 \u03b1\u03bd\u03c4\u03b9\u03c3\u03b5\u03b9\u03c3\u03bc\u03b9\u03ba\u03cc; \u0391\u03c0\u03ac\u03bd\u03c4\u03b7\u03c3\u03b7 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03ba\u03bf\u03cd",
    "blog2_desc": "TBDY 2018, \u03c3\u03cd\u03c3\u03c4\u03b7\u03bc\u03b1 \u03c4\u03bf\u03af\u03c7\u03bf\u03c5 \u03b4\u03b9\u03ac\u03c4\u03bc\u03b7\u03c3\u03b7\u03c2 OSB \u03ba\u03b1\u03b9 \u03c0\u03c1\u03b1\u03b3\u03bc\u03b1\u03c4\u03b9\u03ba\u03ae \u03c3\u03b5\u03b9\u03c3\u03bc\u03b9\u03ba\u03ae \u03b1\u03c0\u03cc\u03b4\u03bf\u03c3\u03b7. \u0395\u03c0\u03b9\u03c3\u03c4\u03b7\u03bc\u03bf\u03bd\u03b9\u03ba\u03ae \u03c3\u03cd\u03b3\u03ba\u03c1\u03b9\u03c3\u03b7 \u03bc\u03b5 \u03bf\u03c0\u03bb\u03b9\u03c3\u03bc\u03ad\u03bd\u03bf \u03c3\u03ba\u03c5\u03c1\u03cc\u03b4\u03b5\u03bc\u03b1 \u03ba\u03b1\u03b9 \u03bf\u03b4\u03b7\u03b3\u03cc\u03c2 \u03ba\u03b1\u03c4\u03b7\u03b3\u03bf\u03c1\u03af\u03b1\u03c2 \u03b5\u03b4\u03ac\u03c6\u03bf\u03c5\u03c2.",
    "blog3_tag": "\u03a4\u03b9\u03bc\u03ad\u03c2",
    "blog3_title": "\u03a4\u03b9\u03bc\u03ad\u03c2 \u03c3\u03c0\u03b9\u03c4\u03b9\u03ce\u03bd \u03b5\u03bb\u03b1\u03c6\u03c1\u03cd \u03c7\u03ac\u03bb\u03c5\u03b2\u03b1 2026: \u03c1\u03b5\u03b1\u03bb\u03b9\u03c3\u03c4\u03b9\u03ba\u03ae \u03b1\u03bd\u03ac\u03bb\u03c5\u03c3\u03b7 \u03ba\u03cc\u03c3\u03c4\u03bf\u03c5\u03c2",
    "blog3_desc": "\u039a\u03cc\u03c3\u03c4\u03bf\u03c2 \u03c5\u03bb\u03b9\u03ba\u03ce\u03bd, \u03b5\u03c1\u03b3\u03b1\u03c3\u03af\u03b1\u03c2 \u03ba\u03b1\u03b9 \u03b5\u03b3\u03ba\u03b1\u03c4\u03ac\u03c3\u03c4\u03b1\u03c3\u03b7\u03c2 \u03b1\u03bd\u03ac \u03bc\u00b2. \u03a3\u03cd\u03b3\u03ba\u03c1\u03b9\u03c3\u03b7 \u03bc\u03b5 \u03bf\u03c0\u03bb\u03b9\u03c3\u03bc\u03ad\u03bd\u03bf \u03c3\u03ba\u03c5\u03c1\u03cc\u03b4\u03b5\u03bc\u03b1.",
    "about_label": "\u03a3\u03c7\u03b5\u03c4\u03b9\u03ba\u03ac",
    "about_title": "\u039f \u03b1\u03be\u03b9\u03cc\u03c0\u03b9\u03c3\u03c4\u03bf\u03c2 \u03c3\u03c5\u03bd\u03b5\u03c1\u03b3\u03ac\u03c4\u03b7\u03c2 \u03c3\u03b1\u03c2 \u03c3\u03b5 \u03b5\u03bb\u03b1\u03c6\u03c1\u03cd \u03c7\u03ac\u03bb\u03c5\u03b2\u03b1",
    "about_desc": "\u0397 MefSteel \u03b9\u03b4\u03c1\u03cd\u03b8\u03b7\u03ba\u03b5 \u03b1\u03c0\u03cc \u03b4\u03cd\u03bf \u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03bf\u03cd\u03c2 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03ba\u03bf\u03cd\u03c2 \u03bc\u03b5 \u03c3\u03b1\u03c6\u03ae \u03c3\u03c4\u03cc\u03c7\u03bf: \u03bd\u03b1 \u03b1\u03bd\u03b1\u03b4\u03b5\u03af\u03be\u03b5\u03b9 \u03c4\u03b7\u03bd \u03c0\u03bb\u03b1\u03c3\u03c4\u03b9\u03bc\u03cc\u03c4\u03b7\u03c4\u03b1 \u2013 \u03c4\u03bf \u03bc\u03b5\u03b3\u03b1\u03bb\u03cd\u03c4\u03b5\u03c1\u03bf \u03c0\u03bb\u03b5\u03bf\u03bd\u03ad\u03ba\u03c4\u03b7\u03bc\u03b1 \u03c4\u03bf\u03c5 \u03b5\u03bb\u03b1\u03c6\u03c1\u03bf\u03cd \u03c7\u03ac\u03bb\u03c5\u03b2\u03b1 \u03c3\u03c4\u03bf\u03c5\u03c2 \u03c3\u03b5\u03b9\u03c3\u03bc\u03bf\u03cd\u03c2 \u2013 \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03b4\u03b5\u03af\u03be\u03b5\u03b9 \u03cc\u03c4\u03b9 \u03b7 \u03c0\u03b1\u03c1\u03b1\u03b3\u03c9\u03b3\u03ae \u03c3\u03b5 \u03b1\u03c5\u03c4\u03cc\u03bd \u03c4\u03bf\u03bd \u03ba\u03bb\u03ac\u03b4\u03bf \u03bc\u03c0\u03bf\u03c1\u03b5\u03af \u03bd\u03b1 \u03b3\u03af\u03bd\u03b5\u03c4\u03b1\u03b9 \u03b1\u03c0\u03cc \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03ba\u03bf\u03cd\u03c2 \u03c0\u03bf\u03c5 \u03ba\u03b1\u03c4\u03b1\u03bd\u03bf\u03bf\u03cd\u03bd \u03c4\u03b7\u03bd \u03b5\u03c0\u03b9\u03c3\u03c4\u03ae\u03bc\u03b7 \u03c0\u03af\u03c3\u03c9 \u03c4\u03b7\u03c2. \u03a3\u03c5\u03bd\u03b4\u03c5\u03ac\u03b6\u03bf\u03bd\u03c4\u03b1\u03c2 \u03c4\u03b7\u03bd \u03b5\u03bc\u03c0\u03b5\u03b9\u03c1\u03af\u03b1 \u03c0\u03b5\u03b4\u03af\u03bf\u03c5 \u03bc\u03b5 \u03c4\u03b7\u03bd \u03c4\u03b5\u03c7\u03bd\u03bf\u03b3\u03bd\u03c9\u03c3\u03af\u03b1 \u03bc\u03b7\u03c7\u03b1\u03bd\u03b9\u03ba\u03bf\u03cd, \u03c5\u03bb\u03bf\u03c0\u03bf\u03b9\u03bf\u03cd\u03bc\u03b5 \u03c4\u03b1 \u03ad\u03c1\u03b3\u03b1 \u03c3\u03b1\u03c2 \u03bc\u03b5 \u03c0\u03bf\u03b9\u03bf\u03c4\u03b9\u03ba\u03ac \u03c5\u03bb\u03b9\u03ba\u03ac, \u03b5\u03be\u03b5\u03b9\u03b4\u03b9\u03ba\u03b5\u03c5\u03bc\u03ad\u03bd\u03b7 \u03c4\u03b5\u03c7\u03bd\u03b9\u03ba\u03ae \u03ba\u03b1\u03b9 \u03ad\u03b3\u03ba\u03b1\u03b9\u03c1\u03b7 \u03c0\u03b1\u03c1\u03ac\u03b4\u03bf\u03c3\u03b7.",
    "about_experience": "\u03a7\u03c1\u03cc\u03bd\u03b9\u03b1 \u03b5\u03bc\u03c0\u03b5\u03b9\u03c1\u03af\u03b1\u03c2",
